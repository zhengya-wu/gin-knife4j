{
  "openapi": "3.0.3",
  "info": {
    "title": "gin-knife4j 示例 API",
    "version": "v1.0.0",
    "description": "原生 OpenAPI 3 文档示例，用于演示 gin-knife4j 的 OpenAPI 3 模式。",
    "contact": {
      "name": "zhengya-wu",
      "email": "zhengya-wu@xxxx.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080/api/v1",
      "description": "本地开发"
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "tags": ["user"],
        "summary": "获取用户列表",
        "description": "返回一个简化的用户列表示例。",
        "operationId": "listUsers",
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": ["order"],
        "summary": "获取订单详情",
        "operationId": "getOrder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "订单 ID"
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "404": {
            "description": "订单不存在"
          }
        },
        "security": [
          {
            "JWT": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "u_1001"
          },
          "name": {
            "type": "string",
            "example": "Alice"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "o_20260328"
          },
          "status": {
            "type": "string",
            "example": "paid"
          }
        }
      }
    },
    "securitySchemes": {
      "JWT": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
